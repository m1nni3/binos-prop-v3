{
  "name": "binos-properties",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "build": "npx tailwindcss -i ./src/input.css -o ./public/output.css --minify",
    "deploy": "npm run build && wrangler deploy",
    "db:init": "wrangler d1 execute pomp --remote --file=migrations/001_schema.sql",
    "db:portals": "wrangler d1 execute pomp_portals --remote --file=migrations/001_portals.sql",
    "genkey": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "wrangler": "^4.104.0"
  }
}
